# Build artefacts (rebuilt in image)
target/
**/target/
**/*.rs.bk
Cargo.lock.bak

# Local SQLite databases — must not leak into images
*.sqlite
*.sqlite-journal
*.db
data/

# Environment, IDE, VCS
.env
.env.*
.vscode/
.idea/
.git/
.github/
.gitignore

# Docs and dev assets
docs/
# openapi.yaml is `include_str!`'d into the binary at build time, so it
# must be visible to the docker context even though the rest of `docs/`
# is excluded.
!docs/openapi.yaml
*.md
README*
LICENSE*

# Tests and fixtures
tests/
fixtures/
**/__pycache__/
**/.pytest_cache/

# Node / TS SDK build output (not needed in the rust image)
sdks/typescript/node_modules/
sdks/typescript/dist/
sdks/typescript/build/

# WASM build (separate Dockerfile if needed)
hippo-wasm/pkg/

# Docker meta
Dockerfile
.dockerignore
docker-compose*.yml
